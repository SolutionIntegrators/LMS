# ── Supabase (per client — from Project Settings → API) ──────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── ThriveCart purchase webhook (shared secret; also passed as ?key= on the URL)
THRIVECART_WEBHOOK_SECRET=

# ── Zapier webhook (optional alternate purchase source) ──────────────────────
ZAPIER_WEBHOOK_SECRET=

# ── Airtable ops hub (optional; personal access token) ───────────────────────
AIRTABLE_TOKEN=
