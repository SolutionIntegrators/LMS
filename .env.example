# ── Supabase (per client — from Project Settings → API) ──────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Purchase webhooks: Dubsado (via Zapier) and Stripe both grant LMS access ──
# Zapier: sent as the x-api-key header to /api/webhooks/zapier
ZAPIER_WEBHOOK_SECRET=
# Stripe: signing secret (whsec_…) from the Stripe webhook endpoint → /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=

# ── Airtable ops hub (optional; personal access token) ───────────────────────
AIRTABLE_TOKEN=

# ── Resend API key for custom transactional emails (e.g. "new access granted").
# Same Resend account used for Supabase auth SMTP; a sending key is fine.
# If unset, those emails are skipped silently (auth emails still send via SMTP).
RESEND_API_KEY=
# Optional: from-address for those emails (defaults to connect@solutionintegrators.us)
EMAIL_FROM=

# ── Kit (ConvertKit) v4 API key — tags buyers in the email tool on purchase.
# Per-product tag mapping is set in the admin product settings. Skips if unset.
KIT_API_KEY=

# ── Cron secret for the daily affiliate-clicks → Airtable sync endpoint.
# Trigger /api/cron/sync-affiliate-clicks?key=CRON_SECRET once a day.
CRON_SECRET=

# ── Secret for the self-service affiliate link-request endpoint
# (/api/affiliate/create-link), called by the Airtable Link Requests automation.
AFFILIATE_LINK_SECRET=
